#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int num;
printf("Enter a number: ");
    scanf("%d",&num);
    int list[num];
    printf("Enter %d elements: ",num);
    for(int i=0;i<num;i++){
        scanf("%d",&list[i]);
    }
    for(int i=0;i<num;i++){
        printf("%d ",list[i]);
    }
    return 0;
}
