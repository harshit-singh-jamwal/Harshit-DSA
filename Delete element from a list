#include<stdio.h>
#include<stdlib.h>
int main(){
    int num;
    printf("Enter number:");
    scanf("%d",&num);
    
    int list[num];
    printf("Enter %d elements: ",num);
    for(int i=0;i<num;i++){
        scanf("%d",&list[i]);
    }
    
    int value,pos=0,found=0;
    printf("Enter value that you have deleted: ");
    scanf("%d",&value);
    
    for(int i=0;i<num;i++){
        if(value==list[i]){
            pos=i;
            found=1;
            break;
        }
    }
    if(found==1){
        printf("list after deletion:");
        for(int i=pos;i<num-1;i++){
            list[i]=list[i+1];
        }
        num--;
        for(int i=0;i<num;i++){
            printf("%d ",list[i]);
        }
    }
    else if(found==0){
        printf("Element not found:");
        for(int i=0;i<num;i++){
            printf("%d ",list[i]);
        }
    }
    return 0;
}
