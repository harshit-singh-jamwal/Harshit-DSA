#include<stdio.h>
#include<stdlib.h>
#define M 100
int main(){
    int num;
    printf("Enter a number: ");
    scanf("%d",&num);
    int list[M];
    printf("Enter %d elements: ",num);
    for(int i=0;i<num;i++){
        scanf("%d",&list[i]);
    }
    int insertions;
    printf("Enter Insertions Operations: ");
    scanf("%d",&insertions);
    while(insertions!=0){
        int value,pos=0;
        printf("Enter a value you have to insert: ");
        scanf("%d",&value);
        printf("Enter a specific position that you want to insert value: ");
        scanf("%d",&pos);
        for(int i=num;i>pos-1;i--){
            list[i]=list[i-1];
        }
        list[pos]=value;
        num++;
        insertions--;
    }
    for(int i=0;i<num;i++){
        printf("%d ",list[i]);
    }
    return 0;
}
