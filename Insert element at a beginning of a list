#include<stdio.h>
#include<stdlib.h>
#include<string.h>
#include<math.h>
int main(){
    int num;
    printf("Enter a number: ");
    scanf("%d",&num);
    int list[num];
    printf("Enter %d elements: ",num);
    for(int i=0;i<num;i++){
        scanf("%d",&list[i]);
    }
    int value,pos=0;
    printf("Enter value that you have to insert in the beginning: ");
    scanf("%d",&value);
    for(int i=num;i>pos-1;i--){
        list[i]=list[i-1];
    }
    list[0]=value;
    num++;
    for(int i=0;i<num;i++){
        printf("%d ",list[i]);
    }
    return 0;
}
