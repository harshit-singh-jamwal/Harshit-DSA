#include<stdio.h>
#include<stdlib.h>
int main(){
    int num;
    printf("Enter a number: ");
    scanf("%d",&num);
    int list[num];
    printf("Enter %d elements: ",num);
    for(int i=0;i<num;i++){
        scanf("%d",&list[i]);
    }
    int value,pos=0;
    printf("Enter a value that you have to insert at specific position: ");
    scanf("%d",&value);
    printf("Enter a position that you have to insert element: ");
    scanf("%d",&pos);
    for(int i=num;i>pos-1;i--){
        list[i]=list[i-1];
    }
    num++;
    list[pos]=value;
    for(int i=0;i<num;i++){
        printf("%d ",list[i]);
    }
    return 0;
}
